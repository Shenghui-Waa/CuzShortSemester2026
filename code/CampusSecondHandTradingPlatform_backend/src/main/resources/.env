# ===================================================
# 校园二手交易平台 - 环境变量配置
# 请根据实际环境填写对应配置值
# ===================================================

# ---- 数据库配置 ----
# MySQL 数据库连接地址
DB_HOST=192.168.164.132
DB_PORT=3306
DB_NAME=cuzssp
# 数据库用户名
DB_USERNAME=root
# 数据库密码
DB_PASSWORD=123456

# ---- JWT 配置 ----
# JWT 签名密钥（至少256位长度，建议使用随机生成的Base64字符串）
JWT_SECRET=WTNWNmMzTndNakF5Tm5kbFluQnliMnBsWTNRPQ==
# JWT 过期时间（毫秒），默认24小时
JWT_EXPIRATION=86400000

# ---- Cloudflare R2 对象存储配置 ----
# R2 账号ID（在Cloudflare控制台 → R2 → 账户设置中查看）
R2_ACCOUNT_ID=455a8b58714ae5eb276aedbdcf02c2ed
# R2 令牌值
R2_TOKEN_VALUE=your_r2_token_value_here(可不填)
# R2 Access Key ID（在Cloudflare控制台 → R2 → 管理API令牌中创建）
R2_ACCESS_KEY_ID=fe1ae63ba486da91550e45d17b726259
# R2 Secret Access Key
R2_SECRET_ACCESS_KEY=fb4e7de85b00f90d44be6f8c9bb1e6a2c5dbe1919abe3164ddbbaf3853c00e14
# R2 存储桶名称
R2_BUCKET_NAME=r2-joss-tsyanst
# R2 存储桶中的子文件夹路径（可选）
R2_CHILD_FOLDER=cuzssp/2026/files/
# R2 Endpoint URL（格式：https://<account-id>.r2.cloudflarestorage.com）
R2_ENDPOINT=https://455a8b58714ae5eb276aedbdcf02c2ed.r2.cloudflarestorage.com
# R2 自定义域名或公共URL（用于图片访问）
R2_PUBLIC_URL=https://r2.josstyanaaa.cc.cd
# R2 区域（固定为 auto）
R2_REGION=auto

# ---- 服务器配置 ----
SERVER_PORT=8080

# ---- 文件上传配置 ----
UPLOAD_MAX_FILE_SIZE=2MB
UPLOAD_MAX_REQUEST_SIZE=10MB
