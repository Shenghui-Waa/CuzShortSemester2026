<?xml version="1.0" encoding="utf-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper
        namespace="com.cuzssp.campussecondhandtradingplatform_backend.mapper.ProductMapper">
    <sql id="commonOrderUse">
        <choose>
            <when test="priceBase != null and priceBase == 1">
                , price ASC
            </when>
            <when test="priceBase != null and priceBase == 0">
                , price DESC
            </when>
        </choose>
    </sql>
    
    <select id="selectAllActive"
            resultType="com.cuzssp.campussecondhandtradingplatform_backend.common.entity.Product">
        SELECT * FROM product
        WHERE status = 1
        ORDER BY created_at DESC
        <include refid="commonOrderUse" />
    </select>

<select id="searchByKeyword"
            resultType="com.cuzssp.campussecondhandtradingplatform_backend.common.entity.Product">
        SELECT * FROM product
        WHERE status = #{status}
          AND (title LIKE CONCAT('%',#{keyword},'%') OR description LIKE CONCAT('%',#{keyword},'%'))
        ORDER BY created_at DESC
        <include refid="commonOrderUse" />
    </select>

<select id="selectByCategoryId"
            resultType="com.cuzssp.campussecondhandtradingplatform_backend.common.entity.Product">
        SELECT * FROM product
        WHERE status = #{status}
          AND category_id = #{categoryId}
        ORDER BY created_at DESC
        <include refid="commonOrderUse" />
    </select>

<select id="selectByCampus"
            resultType="com.cuzssp.campussecondhandtradingplatform_backend.common.entity.Product">
        SELECT * FROM product
        WHERE status = #{status}
          AND campus = #{campus}
        ORDER BY created_at DESC
        <include refid="commonOrderUse" />
    </select>

</mapper>