<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.cuzssp.campussecondhandtradingplatform_backend.mapper.OrderMapper">

    <select id="selectByUserIdOrStatus"
            resultType="com.cuzssp.campussecondhandtradingplatform_backend.common.entity.OrderInfo">
        SELECT * FROM order_info
        WHERE 1 = 1
        <if test="userId != null " >
            AND (buyer_id = #{userId} OR seller_id = #{userId})
        </if>
        <if test="status != null">
            AND status = #{status}
        </if>
        ORDER BY created_at DESC
    </select>

</mapper>