<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.cuzssp.campussecondhandtradingplatform_backend.mapper.CategoryMapper">
    <select id="selectByIds"
            resultType="com.cuzssp.campussecondhandtradingplatform_backend.common.entity.Category">
        SELECT * FROM category
        WHERE id IN
            <foreach collection='ids' item='id' open='(' separator=',' close=')'>
                #{id}
            </foreach>
    </select>
</mapper>