# ===================================================
# 校园二手交易平台 - 环境变量配置
# 请根据实际环境填写对应配置值
# ===================================================

# ---- 数据库配置 ----
# MySQL 数据库连接地址
DB_HOST=localhost
DB_PORT=3306
DB_NAME=your-db-name
# 数据库用户名
DB_USERNAME=root
# 数据库密码
DB_PASSWORD=123456

# ---- JWT 配置 ----
# JWT 签名密钥 明文
JWT_SECRET=your-jwt-secret-key-randomly-generated-base64-string
# JWT 过期时间（毫秒），默认24小时
JWT_EXPIRATION=86400000

# 聊天加密密钥 明文
CHAT_ENCRYPTION_KEY=your-chat-encryption-key-randomly-generated-base64-string

# ---- Cloudflare R2 对象存储配置 ----
# R2 账号ID（在Cloudflare控制台 → R2 → 账户设置中查看）
R2_ACCOUNT_ID=your-r2-account-id
# R2 令牌值
R2_TOKEN_VALUE=your-r2-token-value
# R2 Access Key ID（在Cloudflare控制台 → R2 → 管理API令牌中创建）
R2_ACCESS_KEY_ID=your-r2-access-key-id
# R2 Secret Access Key
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
# R2 存储桶名称
R2_BUCKET_NAME=your-r2-bucket-name
# R2 存储桶中的子文件夹路径（可选）
R2_CHILD_FOLDER=example-folder/
# R2 Endpoint URL（格式：https://<account-id>.r2.cloudflarestorage.com）
R2_ENDPOINT=https://<your-account-id>.r2.cloudflarestorage.com
# R2 自定义域名或公共URL（用于图片访问）
R2_PUBLIC_URL=your-custom-domain
# R2 区域（固定为 auto）
R2_REGION=auto

# ---- 服务器配置 ----
SERVER_PORT=8080

# ---- 文件上传配置 ----
UPLOAD_MAX_FILE_SIZE=2MB
UPLOAD_MAX_REQUEST_SIZE=10MB
