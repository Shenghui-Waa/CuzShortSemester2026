# ===================================================
# 校园二手交易平台 - 环境变量配置
# 请根据实际环境填写对应配置值
# ===================================================

# ---- 数据库配置 ----
# MySQL 数据库连接地址
DB_HOST=your-db-host
DB_PORT=your-db-port
DB_NAME=your-db-name
# 数据库用户名
DB_USERNAME=your-db-username
# 数据库密码
DB_PASSWORD=your-db-password

# ---- 服务器配置 ----
SERVER_PORT=8080

# ---- 文件上传配置 ----
UPLOAD_MAX_FILE_SIZE=2MB
UPLOAD_MAX_REQUEST_SIZE=10MB

# ---- JWT 配置 ----
# JWT 签名密钥 明文
JWT_SECRET=your-jwt-secret-key
# JWT 过期时间（毫秒），默认24小时
JWT_EXPIRATION=86400000

# 聊天加密密钥 明文
CHAT_SECRET_KEY=your-chat-secret-key

# ---- 对象存储配置 ----
# 存储支持商（填r2或oss，默认r2）
STORAGE_SUPPORT=r2
# 账户ID
#   对于R2，在Cloudflare控制台 → R2 → 账户设置中查看；
#   对于OSS,...
ACCOUNT_ID=your-account-id
# Access Key ID
#   对于R2，在Cloudflare控制台 → R2 → 管理API令牌中创建；
#   对于OSS,...
ACCESS_KEY_ID=your-access-key-id
# Secret Access Key
SECRET_ACCESS_KEY=your-secret-access-key
# 存储桶名称
BUCKET_NAME=your-bucket-name
# 存储桶中的子文件夹路径（可选）
CHILD_FOLDER=example/folder/
# Endpoint URL
#   R2 格式：https://<account-id>.r2.cloudflarestorage.com；
#   OSS 格式：
ENDPOINT=https://endpoint.com
# 自定义域名或公共URL（用于图片访问）
PUBLIC_URL=https://example.com
# R2 区域（固定为 auto）；OSS 可不填
REGION=auto
